# Arms control config (see config/ for available configs)
ARMS_CONTROL_CONFIG_FILE=openarm_quest_teleop.yaml

# ROS Domain ID (0-232). Isolates ROS2 traffic between workcells on the same
# network. If unset, communication is restricted to localhost.
# ROS_DOMAIN_ID=0

# CycloneDDS distributed communication (e.g. GPU PC for inference).
# When enabled, RMW switches to CycloneDDS with peer discovery.
ENABLE_CYCLONEDDS=false
CYCLONEDDS_PEER_IP=

# VR teleop
ENABLE_VR_TELEOP=true
# Position scaling for teleop controller input
TELEOP_POSITION_SCALE=1.0

# Camera settings
CAMERA_WIDTH=1920
CAMERA_HEIGHT=1080
CAMERA_FPS=60

# Camera controls
CAMERA_BRIGHTNESS=50
CAMERA_CONTRAST=0
CAMERA_SATURATION=60
CAMERA_HUE=0
CAMERA_GAMMA=100
CAMERA_GAIN=100
CAMERA_POWER_LINE_FREQUENCY=2
CAMERA_SHARPNESS=0
CAMERA_BACKLIGHT_COMPENSATION=64
CAMERA_AUTO_WHITE_BALANCE=true
CAMERA_WHITE_BALANCE=4600
CAMERA_AUTOEXPOSURE=true
CAMERA_EXPOSURE=156
CAMERA_AUTOFOCUS=true
CAMERA_FOCUS=110
CAMERA_ZOOM_ABSOLUTE=0
